{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/wp-content/(.*)", "dest": "/wp-content/$1" },
    { "src": "/wp-includes/(.*)", "dest": "/wp-includes/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}